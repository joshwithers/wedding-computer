# Local development secrets for `wrangler dev`.
# Copy to `.dev.vars` (gitignored) and fill in real values where needed.
# These placeholders are enough to boot the app locally.

SESSION_SECRET=local-dev-secret-key-do-not-use-in-production-abc123
RESEND_API_KEY=re_placeholder
ANTHROPIC_API_KEY=placeholder
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
GOOGLE_CLIENT_ID=placeholder
GOOGLE_CLIENT_SECRET=placeholder
APPLE_CLIENT_ID=placeholder
APPLE_CLIENT_SECRET=placeholder
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Enables GET /dev/login/:email — a session-minting auth bypass for local testing.
# MUST stay out of every deployed environment. The route 404s unless this is
# exactly 'true', so production/self-hosted installs are safe by default.
ENABLE_DEV_LOGIN=true
